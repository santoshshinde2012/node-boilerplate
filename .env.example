# Runtime
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Encryption (response payload encryption helper)
APPLY_ENCRYPTION=false
# 32+ char random secret. Required when APPLY_ENCRYPTION=true.
SECRET_KEY=
# 32+ char hex/base64 fixed salt; ensures encrypted output survives restarts.
ENCRYPTION_SALT=

# Security
# Comma-separated list of allowed origins (use "*" for any in dev only).
CORS_ORIGINS=http://localhost:3000
# Maximum JSON / urlencoded body size.
BODY_LIMIT=1mb
# Window in milliseconds for the global rate limiter.
RATE_LIMIT_WINDOW_MS=60000
# Maximum requests per IP per window.
RATE_LIMIT_MAX=120
# Set to "true" only when running behind a trusted reverse-proxy (nginx, ELB, Cloudflare).
TRUST_PROXY=false

# API surface
# Set to "false" to disable the system status endpoints in production.
EXPOSE_SYSTEM_ROUTES=true
